---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
const { settings, pages, title, description } = Astro.props;
const pageTitle = title ? `${title} | ${settings.siteTitle}` : settings.siteTitle;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description || settings.tagline} />
    <title>{pageTitle}</title>
    <style define:vars={{
      primary: settings.primaryColour,
      background: settings.backgroundColour,
      highlight: settings.highlightColour,
      line: settings.borderColour
    }}></style>
  </head>
  <body>
    <Header settings={settings} pages={pages} />
    <main><slot /></main>
    <Footer settings={settings} />
  </body>
</html>
