---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteData } from '../lib/baserow';
const data = await getSiteData();
---
<BaseLayout settings={data.settings} pages={data.pages} title="Page not found">
  <section class="not-found"><h1>Page not found</h1><p><a class="button" href="/">Return home</a></p></section>
</BaseLayout>
