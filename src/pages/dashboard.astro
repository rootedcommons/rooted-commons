---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionRenderer from '../components/SectionRenderer.astro';
import { getSiteData } from '../lib/baserow';
import { buildSectionBlocks } from '../lib/sections';

const data=await getSiteData();
const page=data.pages.find((item)=>item.slug==='dashboard') || {title:'Your Rooted Commons',intro:'Your weekly market, membership and local food network in one place.',titleSize:'large',introSize:'medium',heroLayout:'none'};
const blocks=buildSectionBlocks(data.sections.filter((section)=>section.page==='dashboard'));
const s=data.settings;
const badgeLogos={
  'Founder 10':s.founder10Badge,
  'Founder 25':s.founder25Badge,
  'Founder 50':s.founder50Badge
};
const membershipPerks=s.membershipPerks || [];
---
<BaseLayout settings={s} pages={data.pages} title={page.seoTitle || page.title} description={page.seoDescription || page.intro}>
  <PageHero page={page} />

  <main class="dashboard-shell">
    <section id="dashboard-loading" class="dashboard-card"><p>Loading your membership…</p></section>
    <section id="dashboard-content" hidden>
      <div class="dashboard-overview">
        <article class="dashboard-card dashboard-welcome">
          <p class="eyebrow">Your weekly market</p>
          <h1 id="dashboard-greeting">Welcome</h1>
          <p class="dashboard-credit"><span>Member credit</span><strong id="dashboard-credit-value">£0.00</strong></p>
          <div id="dashboard-order-status" class="dashboard-status">Orders are open</div>
          <a id="dashboard-shop-link" class="button" href="/orders/">Browse this week’s market</a>
        </article>

        <article class="dashboard-card dashboard-collection">
          <p class="eyebrow">Your collection point</p>
          <h2 id="dashboard-point-name">Not selected</h2>
          <p id="dashboard-point-time"></p>
          <p id="dashboard-point-address"></p>
          <p id="dashboard-point-deadline" class="collection-deadline-readable"></p>
          <a id="dashboard-point-link" class="text-link" hidden>View collection point →</a>
        </article>
      </div>

      <div class="dashboard-detail-grid">
        <article class="dashboard-card dashboard-membership-card">
          <div class="dashboard-membership-copy">
            <p class="eyebrow">Your membership</p>
            <h2 id="dashboard-founder-level">Rooted Commons member</h2>
            <p id="dashboard-member-since"></p>
            <p id="dashboard-last-order"></p>
            <div id="dashboard-perks" class="dashboard-perks"></div>
          </div>
          <div id="dashboard-badge" class="dashboard-badge"></div>
        </article>

        <article class="dashboard-card dashboard-commitment-card">
          <p class="eyebrow">Your weekly commitment</p>
          <p class="commitment-amount"><strong id="dashboard-commitment">£0</strong><span>/week</span></p>
          <p>Your regular contribution creates predictable demand that local producers can plan around.</p>
          <div class="commitment-metrics">
            <div><span>Average weekly orders</span><strong id="dashboard-average-spend">£0.00</strong></div>
            <div id="dashboard-credit-runway-row"><span>Credit runway</span><strong id="dashboard-credit-runway">—</strong></div>
            <div id="dashboard-impact-row"><span>Redirected locally</span><strong id="dashboard-impact">£0.00</strong></div>
          </div>
          <div class="recent-topups">
            <h3>Recent top-ups</h3>
            <div id="dashboard-topups"><p class="small-print">No recent top-ups found.</p></div>
          </div>
          <div id="dashboard-increase-prompt" class="commitment-prompt" hidden>
            <p id="dashboard-increase-copy"></p>
            {s.increaseCommitmentButtonUrl && <a class="button" href={s.increaseCommitmentButtonUrl}>{s.increaseCommitmentButtonText}</a>}
          </div>
        </article>
      </div>
    </section>
  </main>

  {blocks.map((block)=><SectionRenderer block={block} products={data.products} settings={s} />)}

  <script is:inline define:vars={{ badgeLogos, membershipPerks }}>
    const TOKEN_KEY='rooted-commons-order-token-v1';
    const params=new URLSearchParams(location.search);
    const urlToken=params.get('token');
    if(urlToken)localStorage.setItem(TOKEN_KEY,urlToken);
    const token=urlToken||localStorage.getItem(TOKEN_KEY)||'';
    const money=new Intl.NumberFormat('en-GB',{style:'currency',currency:'GBP'});
    const formatDate=value=>value?new Intl.DateTimeFormat('en-GB',{day:'numeric',month:'short',year:'numeric'}).format(new Date(value)):'';
    const formatLocalDeadline=value=>{
      if(!value)return '';
      const parsed=new Date(value);
      if(Number.isNaN(parsed.getTime()))return String(value);
      return new Intl.DateTimeFormat('en-GB',{timeZone:'Europe/London',weekday:'long',hour:'numeric',minute:'2-digit',hour12:true}).format(parsed).replace(' am','am').replace(' pm','pm');
    };
    const relativeDate=value=>{
      if(!value)return 'No previous website order';
      const days=Math.max(0,Math.floor((Date.now()-new Date(value).getTime())/86400000));
      if(days===0)return 'You last ordered today';
      if(days===1)return 'You last ordered yesterday';
      if(days<14)return `You last ordered ${days} days ago`;
      const weeks=Math.floor(days/7);
      return `You last ordered ${weeks} week${weeks===1?'':'s'} ago`;
    };
    const renderPerks=(weeks)=>{
      const perks=(membershipPerks||[]).map(item=>({label:item.label,unlockWeeks:Number(item.unlockWeeks)||0})).filter(item=>item.label);
      const unlocked=perks.filter(item=>weeks>=item.unlockWeeks);
      const next=perks.find(item=>weeks<item.unlockWeeks);
      const container=document.querySelector('#dashboard-perks');
      if(!perks.length){container.hidden=true;return;}
      container.innerHTML=`<h3>You’ve unlocked…</h3>${unlocked.length?`<ul>${unlocked.map(item=>`<li>${item.label}</li>`).join('')}</ul>`:'<p>Your first member perk is on its way.</p>'}${next?`<p class="next-perk"><strong>Next:</strong> ${next.label} — unlocks in ${next.unlockWeeks-weeks} week${next.unlockWeeks-weeks===1?'':'s'}.</p>`:''}`;
    };
    const renderTopups=payments=>{
      const container=document.querySelector('#dashboard-topups');
      if(!payments?.length)return;
      container.innerHTML=payments.map(item=>`<div class="topup-line"><span>${formatDate(item.date)}</span><strong>+${money.format(Math.abs(item.amount||0))}</strong></div>`).join('');
    };
    async function load(){
      if(!token){location.href='/orders/';return;}
      const response=await fetch(`/api/member?token=${encodeURIComponent(token)}`);
      if(!response.ok){document.querySelector('#dashboard-loading').innerHTML='<h2>This secure link is no longer valid</h2><p>Request a new link from checkout or use the latest weekly email.</p>';return;}
      const {member}=await response.json();
      document.querySelector('#dashboard-loading').hidden=true;
      document.querySelector('#dashboard-content').hidden=false;
      document.querySelector('#dashboard-greeting').textContent=`Hi ${member.firstName||'there'}`;
      document.querySelector('#dashboard-credit-value').textContent=money.format(member.credit||0);
      document.querySelector('#dashboard-shop-link').href=`/orders/?token=${encodeURIComponent(token)}`;
      const point=member.collectionPoint||{};
      document.querySelector('#dashboard-point-name').textContent=point.name||'Choose at checkout';
      document.querySelector('#dashboard-point-time').textContent=point.collectionTime||'';
      document.querySelector('#dashboard-point-address').textContent=point.address||'';
      document.querySelector('#dashboard-point-deadline').textContent=point.ordersClose?`Orders close ${formatLocalDeadline(point.ordersClose)} for this slot.`:'';
      const pointLink=document.querySelector('#dashboard-point-link');
      if(point.link){pointLink.href=point.link;pointLink.hidden=false;}
      document.querySelector('#dashboard-founder-level').textContent=member.founderBadge||'Rooted Commons member';
      const weeks=Number(member.membershipWeeks)||0;
      document.querySelector('#dashboard-member-since').textContent=member.membershipWeeks!=null?`${weeks} weeks supporting local producers.`:(member.memberSince?`Member since ${new Date(member.memberSince).toLocaleDateString('en-GB',{month:'long',year:'numeric'})}.`:'');
      document.querySelector('#dashboard-last-order').textContent=member.lastOrder?`${relativeDate(member.lastOrder.submittedAt)} (${money.format(member.lastOrder.total||0)}).`:relativeDate('');
      renderPerks(weeks);
      const logo=badgeLogos[member.founderBadge];
      if(logo)document.querySelector('#dashboard-badge').innerHTML=`<img src="${logo}" alt="${member.founderBadge}">`;

      const commitment=Number(member.weeklyCommitment)||0;
      const average=Number(member.account?.averageWeeklySpend)||0;
      const totalImpact=Number(member.account?.totalOrderSpend)||0;
      document.querySelector('#dashboard-commitment').textContent=money.format(commitment).replace('.00','');
      document.querySelector('#dashboard-average-spend').textContent=money.format(average);
      document.querySelector('#dashboard-impact').textContent=money.format(totalImpact);
      const runway=average>0?(Number(member.credit)||0)/average:0;
      document.querySelector('#dashboard-credit-runway').textContent=runway>0?`${runway.toFixed(runway<2?1:0)} week${Math.round(runway)===1?'':'s'}`:'—';
      renderTopups(member.account?.payments||[]);
      const threshold=Math.max(2,commitment*.15);
      if(commitment>0&&average>=commitment+threshold){
        document.querySelector('#dashboard-increase-prompt').hidden=false;
        document.querySelector('#dashboard-increase-copy').textContent=`Your recent orders average ${money.format(average)} a week, around ${money.format(average-commitment)} more than your current commitment.`;
      }
    }
    load();
  </script>
</BaseLayout>
