---
const { products, category = '', columns = 3, showControls = false, settings = {} } = Astro.props;
const wanted = String(category || '').trim().toLowerCase();
const money = new Intl.NumberFormat('en-GB', { style: 'currency', currency: 'GBP' });
const filtered = wanted
  ? products.filter((product) => (product.categories || [product.category]).some((item) => String(item).trim().toLowerCase() === wanted))
  : products;

const countryCodes = {
  'united kingdom':'GB','uk':'GB','great britain':'GB','england':'GB','scotland':'GB','wales':'GB','northern ireland':'GB',
  'ireland':'IE','italy':'IT','france':'FR','spain':'ES','portugal':'PT','greece':'GR','germany':'DE','belgium':'BE',
  'netherlands':'NL','sweden':'SE','denmark':'DK','norway':'NO','finland':'FI','poland':'PL','austria':'AT','switzerland':'CH',
  'tunisia':'TN','morocco':'MA','turkey':'TR','united states':'US','usa':'US','canada':'CA','india':'IN','china':'CN',
  'sri lanka':'LK','peru':'PE','brazil':'BR','ecuador':'EC','colombia':'CO','south africa':'ZA','new zealand':'NZ','australia':'AU'
};
function flagFor(country='') {
  const code = countryCodes[String(country).trim().toLowerCase()] || (/^[A-Za-z]{2}$/.test(String(country).trim()) ? String(country).trim().toUpperCase() : '');
  return code ? [...code].map((char) => String.fromCodePoint(127397 + char.charCodeAt(0))).join('') : '🌍';
}
const certificationLogos = {
  'soil association': settings.soilAssociationLogo,
  'eu organic': settings.euOrganicLogo,
  'wildfarmed': settings.wildfarmedLogo
};
const cleanValues = (values = []) => values.map((value) => String(value || '').trim()).filter(Boolean);
---
<div class="product-grid" style={`--columns:${columns}`}>
  {filtered.map((product) => {
    const categories = cleanValues(product.categories || [product.category]);
    const subcategories = cleanValues(product.subcategories || [product.subcategory]);
    const countries = cleanValues(product.grownIn || []);
    const certifications = cleanValues(product.certifications || []);
    return (
      <article
        class="product-card"
        data-product-card
        data-categories={categories.join('|')}
        data-subcategories={subcategories.join('|')}
        data-name={String(product.name || '').toLowerCase()}
        data-search={[product.name, product.producer, product.description, ...categories, ...subcategories, ...countries].filter(Boolean).join(' ').toLowerCase()}
        data-id={product.id}
        data-price={product.priceNumber}
        data-popularity={product.popularity ?? product.order ?? 9999}
        data-country={countries[0] || ''}
      >
        <img src={product.image || '/images/placeholder.svg'} alt="" loading="lazy" />
        <div class="product-copy">
          <h3>{product.link ? <a href={product.link}>{product.name}</a> : product.name}</h3>

          <div class="product-producer-row">
            {product.producer ? <p class="product-producer">{product.producer}</p> : <span></span>}
            <div class="product-origin-badges" aria-label="Origin and certification">
              {certifications.map((certification) => {
                const logo = certificationLogos[String(certification).toLowerCase()];
                return logo
                  ? <img class="certification-logo" src={logo} alt={certification} title={certification} loading="lazy" />
                  : <span class="certification-text" title={certification}>{certification}</span>;
              })}
              {countries.map((country) => <span class="country-flag" title={country} aria-label={`Grown in ${country}`}>{flagFor(country)}</span>)}
            </div>
          </div>

          {product.size && <p class="product-size">{product.size}</p>}
          {product.description && <p class="product-description">{product.description}</p>}

          <div class="product-purchase-row">
            <strong class="product-price">{money.format(product.priceNumber || 0)}</strong>
            {showControls && <div class="quantity-control quantity-control-solid" aria-label={`Quantity of ${product.name}`}>
              <button type="button" data-quantity-change="-1" aria-label="Remove one">−</button>
              <output data-quantity>0</output>
              <button type="button" data-quantity-change="1" aria-label="Add one">+</button>
            </div>}
          </div>
        </div>
      </article>
    );
  })}
</div>
{filtered.length === 0 && <p>No products currently match this section.</p>}
